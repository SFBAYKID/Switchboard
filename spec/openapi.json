  "info": {
    "description": "Switchboard \u2014 the Integration Gateway. A standalone, internal-only HTTP API that owns third-party integrations behind one clean, versioned, token-gated contract and returns a uniform response envelope with a normalized result state. Reservations (OpenTable) is the first integration, mock-first.",
    "title": "Switchboard \u2014 Integration Gateway",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/health": {
      "get": {
        "description": "Alias of /healthz for the documented Postman/CI healthcheck.",
        "operationId": "health_health_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Liveness probe (alias)",
        "tags": [
          "system"
        ]
      }
    },
    "/healthz": {
      "get": {
        "description": "Return liveness. No auth, no secrets.",
        "operationId": "healthz_healthz_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Liveness probe",
        "tags": [
          "system"
        ]
      }
    },
    "/v1": {
      "get": {
        "description": "Return the internal API's name, version, and live integrations.",
        "operationId": "version_info_v1_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VersionInfo"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Contract/version info",
        "tags": [
          "system"
        ]
      }
    },
    "/v1/reservations/availability": {
      "post": {
        "description": "Check whether the requested restaurant/date/time/party is available.",
        "operationId": "availability_v1_reservations_availability_post",
        "parameters": [
          {
            "description": "Caller's hard deadline in milliseconds. The effective deadline is min(this, the per-endpoint budget), minus a small safety margin. On exceed, a read returns state=timeout and a write returns state=requires_human. A deadline at/below the safety margin (~50ms) will almost always time out.",
            "in": "header",
            "name": "X-Deadline-Ms",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "minimum": 1,
                  "type": "integer"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Caller's hard deadline in milliseconds. The effective deadline is min(this, the per-endpoint budget), minus a small safety margin. On exceed, a read returns state=timeout and a write returns state=requires_human. A deadline at/below the safety margin (~50ms) will almost always time out.",
              "title": "X-Deadline-Ms"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AvailabilityRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Envelope_AvailabilityResult_"
                }
              }
            },
            "description": "Successful Response"
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            },
            "description": "Invalid request \u2014 error.code=bad_request (state=null)."
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            },
            "description": "Missing/invalid bearer token \u2014 error.code=unauthorized (state=null)."
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            },
            "description": "Unknown tenant, fail closed \u2014 error.code=not_found (state=null)."
          },
          "429": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            },
            "description": "Upstream rate-limited \u2014 state=rate_limited."
          },
          "502": {
            "content": {
              "application/json": {
