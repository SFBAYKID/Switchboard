{
  "components": {
    "schemas": {
      "AvailabilityRequest": {
        "description": "`POST /v1/reservations/availability` body (real-time, deadline-budgeted).",
        "properties": {
          "date": {
            "format": "date",
            "title": "Date",
            "type": "string"
          },
          "party_size": {
            "maximum": 100.0,
            "minimum": 1.0,
            "title": "Party Size",
            "type": "integer"
          },
          "restaurant_id": {
            "description": "Switchboard restaurant identifier (NOT the OpenTable RID/key).",
            "maxLength": 64,
            "minLength": 1,
            "pattern": "^[A-Za-z0-9_-]+$",
            "title": "Restaurant Id",
            "type": "string"
          },
          "time": {
            "description": "HH:MM (24-hour, restaurant local).",
            "pattern": "^([01][0-9]|2[0-3]):[0-5][0-9]$",
            "title": "Time",
            "type": "string"
          }
        },
        "required": [
          "restaurant_id",
          "date",
          "time",
          "party_size"
        ],
        "title": "AvailabilityRequest",
        "type": "object"
      },
      "AvailabilityResult": {
        "description": "`data` for availability.\n\n`state` is `available` when the REQUESTED date/time is bookable, else\n`unavailable`. `slots` lists the open slots that day (the requested one if open,\nplus alternatives) so the caller can offer options either way.",
        "properties": {
          "slots": {
            "items": {
              "$ref": "#/components/schemas/AvailabilitySlot"
            },
            "title": "Slots",
            "type": "array"
          },
          "state": {
            "enum": [
              "available",
              "unavailable"
            ],
            "title": "State",
            "type": "string"
          }
        },
        "required": [
          "state",
          "slots"
        ],
        "title": "AvailabilityResult",
        "type": "object"
      },
      "AvailabilitySlot": {
        "description": "One bookable slot (date + HH:MM time + the party size it was checked for).",
        "properties": {
          "date": {
            "format": "date",
            "title": "Date",
            "type": "string"
          },
          "party_size": {
            "title": "Party Size",
            "type": "integer"
          },
          "time": {
            "description": "HH:MM (24-hour, restaurant local).",
            "pattern": "^([01][0-9]|2[0-3]):[0-5][0-9]$",
            "title": "Time",
            "type": "string"
          }
        },
        "required": [
          "date",
          "time",
          "party_size"
        ],
        "title": "AvailabilitySlot",
        "type": "object"
      },
      "BookingRequest": {
        "description": "`POST /v1/reservations/book` body (a consequential write \u2014 Rule 9 / review #5).\n\nRetry-safety is provided by the REQUIRED `Idempotency-Key` request header, NOT a\nbody field: a retried book with the same key must not create a second booking.",
        "properties": {
          "customer": {
            "$ref": "#/components/schemas/Customer"
          },
          "date": {
            "format": "date",
            "title": "Date",
            "type": "string"
          },
          "notes": {
            "anyOf": [
              {
                "maxLength": 1000,
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Notes"
          },
          "party_size": {
            "maximum": 100.0,
            "minimum": 1.0,
            "title": "Party Size",
            "type": "integer"
          },
          "restaurant_id": {
            "description": "Switchboard restaurant identifier (NOT the OpenTable RID/key).",
            "maxLength": 64,
            "minLength": 1,
            "pattern": "^[A-Za-z0-9_-]+$",
            "title": "Restaurant Id",
            "type": "string"
          },
          "time": {
            "description": "HH:MM (24-hour, restaurant local).",
            "pattern": "^([01][0-9]|2[0-3]):[0-5][0-9]$",
            "title": "Time",
            "type": "string"
          }
        },
        "required": [
          "restaurant_id",
          "date",
          "time",
          "party_size",
          "customer"
        ],
        "title": "BookingRequest",
        "type": "object"
      },
      "BookingResult": {
        "description": "`data` for book: an actual confirmation only (`state` always `confirmed`).",
        "properties": {
          "confirmation_id": {
            "title": "Confirmation Id",
            "type": "string"
          },
          "state": {
            "const": "confirmed",
            "title": "State",
            "type": "string"
          }
        },
        "required": [
          "state",
          "confirmation_id"
        ],
        "title": "BookingResult",
        "type": "object"
      },
      "CancelRequest": {
        "description": "`POST /v1/reservations/cancel` body (a consequential write). Idempotency-Key required.",
        "properties": {
          "confirmation_id": {
            "maxLength": 200,
            "minLength": 1,
