      "ErrorEnvelope": {
        "description": "The uniform envelope on a FAILURE path, as a concrete (non-generic) model.\n\nUsed to DOCUMENT error responses in the OpenAPI spec (the routes reference it via\n`responses=`), so the published contract tells the truth about 4xx/5xx \u2014 not just\nthe 200 success shape. It is shape-identical to `Envelope` with `ok=false` and\n`data=null`; the runtime error body is produced by `error_envelope_dict()`.",
        "properties": {
          "data": {
            "title": "Data",
            "type": "null"
          },
          "error": {
            "$ref": "#/components/schemas/ErrorInfo"
          },
          "latency_ms": {
            "title": "Latency Ms",
            "type": "integer"
          },
          "mock": {
            "title": "Mock",
            "type": "boolean"
          },
          "ok": {
            "const": false,
            "default": false,
            "title": "Ok",
            "type": "boolean"
          },
          "request_id": {
            "title": "Request Id",
            "type": "string"
          },
          "source": {
            "title": "Source",
            "type": "string"
          },
          "state": {
            "anyOf": [
              {
                "enum": [
                  "available",
                  "unavailable",
                  "confirmed",
                  "modified",
                  "cancelled",
                  "timeout",
                  "auth_error",
                  "rate_limited",
                  "unknown",
                  "requires_human"
                ],
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "State"
          }
        },
        "required": [
          "error",
          "source",
          "latency_ms",
          "mock",
          "request_id"
        ],
        "title": "ErrorEnvelope",
        "type": "object"
      },
