        "required": [
          "restaurant_id",
          "confirmation_id"
        ],
        "title": "CancelRequest",
        "type": "object"
      },
      "CancelResult": {
        "description": "`data` for cancel: the confirmation id + `cancelled` state.",
        "properties": {
          "confirmation_id": {
            "title": "Confirmation Id",
            "type": "string"
          },
          "state": {
            "const": "cancelled",
            "title": "State",
            "type": "string"
          }
        },
        "required": [
          "state",
          "confirmation_id"
        ],
        "title": "CancelResult",
        "type": "object"
      },
      "Customer": {
        "description": "The guest the reservation is for. `name` + `phone` are required for a booking.",
        "properties": {
          "email": {
