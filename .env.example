# ── Switchboard .env.example (committed; value-free template) ──────────────────
# Copy to `.env` and fill in real values. The real `.env` is gitignored and holds
# Switchboard's OWN secrets — never commit it, never log it (CLAUDE.md Rule 7).
# `core/config.py` validates the required vars at startup and FAILS LOUDLY if a
# required one is missing or invalid.
#
# Every variable below maps 1:1 to a field in core/config.py (keep them in sync).
# All values are Switchboard's OWN, defined fresh for this project (isolation rule).

# ── Deployment environment + mock safety (REQUIRED posture) ─────────────────────
# SWITCHBOARD_ENV: "development" | "production". Default "development".
# In production, RESERVATIONS_BACKEND=mock is REFUSED unless the explicit override
# below is set — so fabricated mock data can never be served in prod by accident.
SWITCHBOARD_ENV=development
# SWITCHBOARD_ALLOW_MOCK_IN_PROD: "true" only if you truly intend to serve mock data
# in production. Leave unset/false otherwise.
SWITCHBOARD_ALLOW_MOCK_IN_PROD=false

# ── Internal API auth (REQUIRED) ───────────────────────────────────────────────
# The bearer token that gates EVERY internal request (Authorization: Bearer <token>).
# Switchboard's own secret. Min length 8. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SWITCHBOARD_API_TOKEN=

# ── Reservations integration backend selection (REQUIRED, defaults to mock) ─────
# "mock" | "opentable". Stays "mock" until real OpenTable partner approval; flipping
# to "opentable" is the go-live action and changes NOTHING for callers.
RESERVATIONS_BACKEND=mock

# ── Per-tenant upstream credentials (REQUIRED: at least one tenant) ─────────────
# `tenant` in a request is an IDENTIFIER, never a credential. Switchboard resolves
# the tenant's upstream secret itself, from here. Convention (namespaced by vendor
# and tenant, tenant uppercased):  SWITCHBOARD_OPENTABLE__<TENANT>__API_KEY
# In MOCK mode these can be any non-empty placeholder (the mock makes no real call,
# but credential resolution + per-tenant isolation are still exercised). In REAL mode
# each must be that tenant's actual OpenTable API key. Add one line per tenant.
#
# OpenTable pairs the API key with a per-restaurant RID (Restaurant ID). The RID is an
# identifier (not a secret), optional today (the mock ignores it) but REQUIRED for real
# go-live — set both halves per tenant so go-live is just dropping in the values:
#   SWITCHBOARD_OPENTABLE__<TENANT>__API_KEY  (secret)
#   SWITCHBOARD_OPENTABLE__<TENANT>__RID      (restaurant id)
SWITCHBOARD_OPENTABLE__DEMO__API_KEY=
SWITCHBOARD_OPENTABLE__DEMO__RID=
SWITCHBOARD_OPENTABLE__ACME__API_KEY=
SWITCHBOARD_OPENTABLE__ACME__RID=

# ── Per-endpoint latency budgets (OPTIONAL; sensible defaults) ──────────────────
# Budgets are PER-ENDPOINT (review #4), not one flat number. The effective deadline
# for a request is min(endpoint budget, caller X-Deadline-Ms). The safety margin is
# reserved to build/return the envelope within budget and MUST be strictly below
# every budget (validated at startup).
SWITCHBOARD_AVAILABILITY_BUDGET_MS=1500
SWITCHBOARD_BOOKING_BUDGET_MS=1500
SWITCHBOARD_BUDGET_SAFETY_MARGIN_MS=50

# ── Mock backend behavior knobs (OPTIONAL; mock mode only; hostile-by-design) ───
# Let the mock model real-life conditions so callers exercise degrade paths BEFORE
# the real backend exists. NOT part of the public API contract.
#   MOCK_RESERVATIONS_DELAY_MS : artificial upstream delay in ms (0 = instant). Use a
#                                value above a budget/deadline to exercise timeouts.
#   MOCK_RESERVATIONS_FAIL     : "none" | "auth_error" | "rate_limited" | "unknown"
#                                | "booking_race" (book -> requires_human)
#                                | "slot_gone"    (book -> unavailable)
#   MOCK_RESERVATIONS_SEED_PATH : path to the JSON seed for the stateful mock store.
#                                Unset -> bundled default data/mock_reservations.json
MOCK_RESERVATIONS_DELAY_MS=0
MOCK_RESERVATIONS_FAIL=none
MOCK_RESERVATIONS_SEED_PATH=
