# ── Switchboard .env.example (committed; value-free template) ──────────────────
# Copy to `.env` and fill in real values. The real `.env` is gitignored and holds
# Switchboard's OWN secrets — never commit it, never log it (CLAUDE.md Rule 7).
# `core/config.py` validates the required vars at startup and FAILS LOUDLY if a
# required one is missing.
#
# Labeling: every value below is Switchboard's OWN, defined fresh for this project.
# Nothing here is borrowed from any pre-existing infrastructure (isolation rule).

# ── Internal API auth (REQUIRED) ───────────────────────────────────────────────
# The bearer token that gates EVERY internal request (Authorization: Bearer <token>).
# This is Switchboard's own secret. Generate a strong random value, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# (Per-caller tokens + rotation are a planned extension — for the MVP this is one
#  shared token. Min length 8.)
SWITCHBOARD_API_TOKEN=

# ── Reservations integration backend selection (REQUIRED, defaults to mock) ─────
# Which backend the reservations module uses: "mock" | "opentable".
# Stays "mock" until real OpenTable partner approval lands; flipping to "opentable"
# is the go-live action and changes NOTHING for callers (same contract).
RESERVATIONS_BACKEND=mock

# ── Per-tenant upstream credentials (REQUIRED: at least one tenant) ─────────────
# `tenant` in a request is an IDENTIFIER, never a credential. Switchboard resolves
# the tenant's upstream secret itself, from here. Convention (namespaced by vendor
# and tenant, tenant is uppercased):
#   SWITCHBOARD_OPENTABLE__<TENANT>__API_KEY
# In MOCK mode these can be any non-empty placeholder (the mock makes no real call,
# but credential resolution + per-tenant isolation are still exercised). In REAL
# mode each must be that tenant's actual OpenTable API key.
# Add one line per tenant you serve:
SWITCHBOARD_OPENTABLE__DEMO__API_KEY=
SWITCHBOARD_OPENTABLE__ACME__API_KEY=

# ── Latency budget for real-time endpoints (OPTIONAL; sensible defaults) ────────
# Real-time endpoints (e.g. reservations availability) carry a HARD budget. The
# upstream timeout MUST be strictly below the budget so Switchboard can always
# answer within budget — with the result OR a clean timeout envelope (Rule 5).
SWITCHBOARD_REALTIME_BUDGET_MS=1500
SWITCHBOARD_UPSTREAM_TIMEOUT_MS=1200

# ── Mock backend behavior knobs (OPTIONAL; mock mode only) ─────────────────────
# Let the mock model real-life conditions so callers exercise their degrade paths
# BEFORE the real backend exists (architecture.md: mock should model a slow
# response and an upstream error). These are mock-backend config, NOT part of the
# public API contract.
#   MOCK_RESERVATIONS_DELAY_MS : artificial upstream delay in ms (0 = instant)
#   MOCK_RESERVATIONS_FAIL     : "none" | "error" (force a simulated upstream error)
MOCK_RESERVATIONS_DELAY_MS=0
MOCK_RESERVATIONS_FAIL=none
